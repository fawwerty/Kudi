# ─── Bankly Backend — Environment Variables ───────────────────────
# Copy this file: cp .env.example .env
# Fill in all values before running in production.

# ── Server ──────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development            # production | development

# ── JWT (CHANGE THESE IN PRODUCTION!) ───────────────────────────────
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_AT_LEAST_64_CHARS
JWT_REFRESH_SECRET=ANOTHER_LONG_RANDOM_SECRET_FOR_REFRESH_TOKENS

# ── Database (PostgreSQL) ────────────────────────────────────────────
DATABASE_URL=postgresql://bankly_user:password@localhost:5432/bankly_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bankly_db
DB_USER=bankly_user
DB_PASSWORD=your_db_password

# ── Redis (sessions & caching) ───────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── AI Backend ───────────────────────────────────────────────────────
AI_API_URL=http://localhost:8001

# ── Frontend URL (CORS) ──────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Paystack (Ghana MoMo payments) ──────────────────────────────────
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key_here
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key_here

# ── Twilio (WhatsApp chatbot) ────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ── Email (SendGrid) ─────────────────────────────────────────────────
SENDGRID_API_KEY=your_sendgrid_api_key
EMAIL_FROM=no-reply@bankly.gh
